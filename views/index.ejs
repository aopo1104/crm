<%- include('partials/header') %>
<div class="p-6 space-y-6">
  <div>
    <h1 class="text-2xl font-bold">工作台</h1>
    <p class="text-gray-500">欢迎回来，张总。以下是今日待办概览。</p>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
    <a href="/leads" class="stat-card">
      <div class="flex justify-between items-center mb-2">
        <span class="text-sm text-gray-500 font-medium">公海线索</span>
        <span class="text-lg">🌐</span>
      </div>
      <div class="text-2xl font-bold"><%= publicLeadsCount %></div>
      <p class="text-xs text-gray-500 mt-1">公海线索（待认领）</p>
    </a>
    <a href="/customers" class="stat-card">
      <div class="flex justify-between items-center mb-2">
        <span class="text-sm text-gray-500 font-medium">客户总数</span>
        <span class="text-lg">🏢</span>
      </div>
      <div class="text-2xl font-bold"><%= customersCount %></div>
      <p class="text-xs text-gray-500 mt-1">活跃客户</p>
    </a>
    <a href="/approvals" class="stat-card border-yellow-200">
      <div class="flex justify-between items-center mb-2">
        <span class="text-sm text-gray-500 font-medium">待审批</span>
        <span class="text-lg">✅</span>
      </div>
      <div class="text-2xl font-bold text-yellow-600"><%= pendingApprovals.length %></div>
      <p class="text-xs text-gray-500 mt-1">需要您处理</p>
    </a>
    <a href="/promotions" class="stat-card">
      <div class="flex justify-between items-center mb-2">
        <span class="text-sm text-gray-500 font-medium">进行中推广</span>
        <span class="text-lg">📋</span>
      </div>
      <div class="text-2xl font-bold"><%= activeTasks.length %></div>
      <p class="text-xs text-gray-500 mt-1">推广任务执行中</p>
    </a>
  </div>

  <!-- Panels -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

    <!-- Reminders -->
    <div class="card">
      <div class="card-header flex items-center gap-2">
        <span>⚠️</span>
        <h2 class="font-semibold text-base">智能提醒</h2>
      </div>
      <div class="card-content space-y-2">
        <% allReminders.forEach(r => { %>
        <a href="<%= r.link %>" class="flex items-center justify-between p-3 rounded-lg bg-gray-50 hover:bg-gray-100 transition-colors">
          <div class="flex items-center gap-2">
            <span><%= r.type==='warning'?'🕐':'🔔' %></span>
            <span class="text-sm"><%= r.text %></span>
          </div>
          <span class="text-gray-400">›</span>
        </a>
        <% }) %>
        <% if(allReminders.length===0) { %><p class="text-sm text-gray-400 py-2">暂无提醒</p><% } %>
      </div>
    </div>

    <!-- Pending Approvals -->
    <div class="card">
      <div class="card-header flex items-center gap-2">
        <span>✅</span>
        <h2 class="font-semibold text-base">待审批事项</h2>
      </div>
      <div class="card-content space-y-2">
        <% pendingApprovals.forEach(a => { %>
        <a href="/approvals" class="flex items-center justify-between p-3 rounded-lg bg-gray-50 hover:bg-gray-100 transition-colors">
          <div>
            <p class="text-sm font-medium"><%= a.title %></p>
            <p class="text-xs text-gray-500"><%= a.description %></p>
          </div>
          <span class="badge badge-yellow">待审批</span>
        </a>
        <% }) %>
        <% if(pendingApprovals.length===0) { %><p class="text-sm text-gray-400 py-2">暂无待审批</p><% } %>
      </div>
    </div>

    <!-- Active Promotion Tasks -->
    <div class="card">
      <div class="card-header flex items-center justify-between">
        <div class="flex items-center gap-2"><span>📋</span><h2 class="font-semibold text-base">待执行推广任务</h2></div>
        <a href="/promotions" class="btn btn-ghost btn-sm">查看全部</a>
      </div>
      <div class="card-content space-y-2">
        <% activeTasks.forEach(t => { %>
        <a href="/promotions/<%= t.id %>" class="flex items-center justify-between p-3 rounded-lg bg-gray-50 hover:bg-gray-100 transition-colors">
          <div>
            <p class="text-sm font-medium"><%= t.name %></p>
            <p class="text-xs text-gray-500">已发送 <%= t.sentCount %>/<%= t.totalTarget %> · 截止 <%= t.deadline %></p>
          </div>
          <span class="badge badge-blue">进行中</span>
        </a>
        <% }) %>
      </div>
    </div>

    <!-- Recent Quotes -->
    <div class="card">
      <div class="card-header flex items-center justify-between">
        <div class="flex items-center gap-2"><span>📄</span><h2 class="font-semibold text-base">最近报价</h2></div>
        <a href="/quotes" class="btn btn-ghost btn-sm">查看全部</a>
      </div>
      <div class="card-content space-y-2">
        <% recentQuotes.forEach(q => { %>
        <a href="/customers/<%= q.customerId %>?tab=quotes" class="flex items-center justify-between p-3 rounded-lg bg-gray-50 hover:bg-gray-100 transition-colors">
          <div>
            <p class="text-sm font-medium"><%= q.customerName %></p>
            <p class="text-xs text-gray-500">$<%= q.totalAmount.toLocaleString() %> · <%= q.createdAt %></p>
          </div>
          <span class="badge <%= quoteStatusMap[q.status].color %>"><%= quoteStatusMap[q.status].label %></span>
        </a>
        <% }) %>
      </div>
    </div>

  </div>
</div>
<%- include('partials/footer') %>
