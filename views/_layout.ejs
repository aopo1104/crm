<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CRM 系统</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    .badge { display:inline-flex;align-items:center;border-radius:9999px;padding:2px 10px;font-size:.75rem;font-weight:500;border:1px solid transparent; }
    .badge-gray { background:#f3f4f6;color:#374151; }
    .badge-blue { background:#dbeafe;color:#1d4ed8; }
    .badge-purple { background:#ede9fe;color:#6d28d9; }
    .badge-green { background:#dcfce7;color:#15803d; }
    .badge-yellow { background:#fef9c3;color:#a16207; }
    .badge-orange { background:#ffedd5;color:#c2410c; }
    .badge-red { background:#fee2e2;color:#b91c1c; }
    .sidebar { width:224px;flex-shrink:0; }
    .main-content { margin-left:224px; }
    @media(max-width:768px){.sidebar{display:none}.main-content{margin-left:0}}
    .nav-active { background:rgba(99,102,241,.1);color:#4f46e5; }
    .nav-item { display:flex;align-items:center;gap:12px;border-radius:6px;padding:7px 12px;font-size:.875rem;font-weight:500;color:#6b7280;text-decoration:none;transition:all .15s; }
    .nav-item:hover { background:#f3f4f6;color:#111827; }
    .card { background:#fff;border:1px solid #e5e7eb;border-radius:.5rem; }
    .card-header { padding:16px 20px 12px; }
    .card-content { padding:0 20px 16px; }
    .btn { display:inline-flex;align-items:center;justify-content:center;gap:6px;border-radius:6px;padding:6px 14px;font-size:.875rem;font-weight:500;cursor:pointer;text-decoration:none;border:1px solid transparent;transition:all .15s; }
    .btn-primary { background:#4f46e5;color:#fff;border-color:#4f46e5; }
    .btn-primary:hover { background:#4338ca; }
    .btn-outline { background:#fff;color:#374151;border-color:#d1d5db; }
    .btn-outline:hover { background:#f9fafb; }
    .btn-sm { padding:4px 10px;font-size:.8rem; }
    .btn-ghost { background:transparent;color:#374151;border-color:transparent; }
    .btn-ghost:hover { background:#f3f4f6; }
    .filter-btn { padding:5px 12px;border-radius:6px;border:1px solid #d1d5db;background:#fff;font-size:.8rem;cursor:pointer;transition:all .15s; }
    .filter-btn.active { background:#4f46e5;color:#fff;border-color:#4f46e5; }
    .input { border:1px solid #d1d5db;border-radius:6px;padding:7px 12px;font-size:.875rem;outline:none;width:100%; }
    .input:focus { border-color:#4f46e5;box-shadow:0 0 0 2px rgba(79,70,229,.15); }
    .table th { padding:10px 12px;font-size:.8rem;color:#6b7280;font-weight:500;text-align:left;border-bottom:1px solid #e5e7eb; }
    .table td { padding:10px 12px;font-size:.875rem;border-bottom:1px solid #f3f4f6;vertical-align:middle; }
    .table tr:hover td { background:#f9fafb; }
    .tab-btn { padding:8px 16px;border-radius:6px;border:1px solid #d1d5db;background:#fff;font-size:.875rem;font-weight:500;cursor:pointer;transition:all .15s;display:inline-flex;align-items:center;gap:6px; }
    .tab-btn.active { background:#4f46e5;color:#fff;border-color:#4f46e5; }
    .tab-panel { display:none; }
    .tab-panel.active { display:block; }
  </style>
</head>
<body class="bg-gray-50 min-h-screen flex">

  <!-- Sidebar -->
  <aside class="sidebar fixed left-0 top-0 h-screen border-r bg-white flex flex-col z-40">
    <div class="flex h-14 items-center px-4 border-b gap-2">
      <span style="font-size:1.4rem">📢</span>
      <span class="font-bold text-lg">CRM 系统</span>
    </div>
    <nav class="flex-1 overflow-y-auto py-2 px-2 space-y-0.5">

      <a href="/" class="nav-item <%= page==='workbench'?'nav-active':'' %>">
        <span>🏠</span> 工作台
      </a>

      <p class="px-3 py-1 text-xs font-medium text-gray-400 uppercase tracking-wider mt-2">线索管理</p>
      <a href="/leads" class="nav-item <%= page==='leads'?'nav-active':'' %>">
        <span>🌐</span> 线索管理
      </a>
      <a href="/leads/search" class="nav-item <%= page==='leads-search'?'nav-active':'' %>">
        <span>🔍</span> 线索查重
      </a>

      <p class="px-3 py-1 text-xs font-medium text-gray-400 uppercase tracking-wider mt-2">客户管理</p>
      <a href="/customers" class="nav-item <%= page==='customers'?'nav-active':'' %>">
        <span>🏢</span> 客户列表
      </a>

      <p class="px-3 py-1 text-xs font-medium text-gray-400 uppercase tracking-wider mt-2">报价管理</p>
      <a href="/quotes" class="nav-item <%= page==='quotes'?'nav-active':'' %>">
        <span>📄</span> 报价列表
      </a>
      <a href="/approvals" class="nav-item <%= page==='approvals'?'nav-active':'' %>">
        <span>✅</span> 审批中心
      </a>

      <p class="px-3 py-1 text-xs font-medium text-gray-400 uppercase tracking-wider mt-2">推广管理</p>
      <a href="/promotions" class="nav-item <%= page==='promotions'?'nav-active':'' %>">
        <span>📋</span> 推广任务
      </a>
      <a href="/promotions/monitor" class="nav-item <%= page==='promotions-monitor'?'nav-active':'' %>">
        <span>📊</span> 监控看板
      </a>

      <p class="px-3 py-1 text-xs font-medium text-gray-400 uppercase tracking-wider mt-2">数据分析</p>
      <a href="/reports" class="nav-item <%= page==='reports'?'nav-active':'' %>">
        <span>📈</span> 报表中心
      </a>

      <div class="border-t mt-2 pt-2">
        <a href="/settings" class="nav-item <%= page==='settings'?'nav-active':'' %>">
          <span>⚙️</span> 系统设置
        </a>
      </div>
    </nav>
  </aside>

  <!-- Main -->
  <main class="main-content flex-1 min-h-screen">
    <%- body %>
  </main>

</body>
</html>
