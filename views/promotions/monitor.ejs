<%- include('../partials/header') %>
<div class="p-6 space-y-6">
  <div>
    <h1 class="text-2xl font-bold">推广监控看板</h1>
    <p class="text-gray-500">实时追踪推广任务效果</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <% promotionTasks.forEach(t => { %>
    <% const pct = t.totalTarget>0 ? Math.round(t.sentCount/t.totalTarget*100) : 0; %>
    <a href="<%= base %>/promotions/<%= t.id %>" class="stat-card">
      <div class="flex items-center justify-between mb-3">
        <h3 class="font-semibold text-sm"><%= t.name %></h3>
        <span class="badge <%= taskStatusMap[t.status].color %>"><%= taskStatusMap[t.status].label %></span>
      </div>
      <p class="text-xs text-gray-500 mb-2"><%= t.productName %> · <%= t.channel %></p>
      <div class="mb-2">
        <div class="flex justify-between text-xs mb-1"><span>发送进度</span><span><%= t.sentCount %>/<%= t.totalTarget %></span></div>
        <div class="bg-gray-200 rounded-full h-2">
          <div class="bg-indigo-500 h-2 rounded-full" style="width:<%= pct %>%"></div>
        </div>
      </div>
      <div class="grid grid-cols-3 gap-2 text-center mt-3">
        <div><p class="text-xs text-gray-500">打开率</p><p class="font-semibold text-sm text-blue-600"><%= t.openRate %></p></div>
        <div><p class="text-xs text-gray-500">回复率</p><p class="font-semibold text-sm text-purple-600"><%= t.replyRate %></p></div>
        <div><p class="text-xs text-gray-500">转化率</p><p class="font-semibold text-sm text-green-600"><%= t.convertRate %></p></div>
      </div>
      <p class="text-xs text-gray-400 mt-3">截止 <%= t.deadline %></p>
    </a>
    <% }) %>
  </div>
</div>
<%- include('../partials/footer') %>
